<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Mythfall.Client.ViewModels"
             xmlns:models="clr-namespace:Mythfall.Client.Models"
             x:Class="Mythfall.Client.Pages.HeroesListPage"
             x:DataType="vm:HeroesListViewModel"
             BackgroundColor="#1a2a1a"
             Title="Heroes"
             Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto,*,Auto,Auto" Padding="0">

        <!-- TOP: Resource Bar -->
        <Grid Grid.Row="0"
              Padding="16,24,16,12"
              ColumnDefinitions="*,*,*">

            <!-- Gold -->
            <HorizontalStackLayout Grid.Column="0" Spacing="8" HorizontalOptions="Center" VerticalOptions="Center">
                <Image Source="icon_gold_coin.png" WidthRequest="48" HeightRequest="48" VerticalOptions="Center" />
                <Label Text="{Binding Resources.Gold}" FontSize="18" FontAttributes="Bold"
                       TextColor="#e8d8a0" FontFamily="OpenSansSemibold" VerticalOptions="Center" />
            </HorizontalStackLayout>

            <!-- Experience -->
            <HorizontalStackLayout Grid.Column="1" Spacing="8" HorizontalOptions="Center" VerticalOptions="Center">
                <Image Source="icon_blue_rock.png" WidthRequest="48" HeightRequest="48" VerticalOptions="Center" />
                <Label Text="{Binding Resources.Experience}" FontSize="18" FontAttributes="Bold"
                       TextColor="#88ccee" FontFamily="OpenSansSemibold" VerticalOptions="Center" />
            </HorizontalStackLayout>

            <!-- Special Experience -->
            <HorizontalStackLayout Grid.Column="2" Spacing="8" HorizontalOptions="Center" VerticalOptions="Center">
                <Image Source="icon_pink_rock.png" WidthRequest="48" HeightRequest="48" VerticalOptions="Center" />
                <Label Text="{Binding Resources.SpecialExperience}" FontSize="18" FontAttributes="Bold"
                       TextColor="#ee88cc" FontFamily="OpenSansSemibold" VerticalOptions="Center" />
            </HorizontalStackLayout>
        </Grid>

        <!-- Hero Grid -->
        <CollectionView Grid.Row="1" ItemsSource="{Binding Heroes}" Margin="12,0">
            <CollectionView.ItemsLayout>
                <GridItemsLayout Orientation="Vertical" Span="3"
                                 HorizontalItemSpacing="12" VerticalItemSpacing="12" />
            </CollectionView.ItemsLayout>
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:Hero">
                    <Border BackgroundColor="#2a4a2a" Stroke="{Binding RankColor}"
                            StrokeThickness="3" StrokeShape="RoundRectangle 10"
                            Padding="8" HeightRequest="140">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer
                                Command="{Binding Source={RelativeSource AncestorType={x:Type vm:HeroesListViewModel}}, Path=SelectHeroCommand}"
                                CommandParameter="{Binding .}" />
                        </Border.GestureRecognizers>
                        <VerticalStackLayout HorizontalOptions="Center" Spacing="4"
                                             VerticalOptions="Center">
                            <!-- Faction badge -->
                            <Image Source="{Binding FactionIcon}" WidthRequest="18" HeightRequest="18"
                                   HorizontalOptions="Center" />
                            <Image Source="{Binding IconImage}"
                                   WidthRequest="54" HeightRequest="54"
                                   HorizontalOptions="Center" />
                            <Label Text="{Binding Name}" FontSize="12" FontAttributes="Bold"
                                   TextColor="#e8d8a0" HorizontalOptions="Center"
                                   HorizontalTextAlignment="Center"
                                   FontFamily="OpenSansSemibold" />
                            <Label FontSize="11" TextColor="{Binding RankColor}"
                                   HorizontalOptions="Center" FontFamily="OpenSansSemibold">
                                <Label.Text>
                                    <MultiBinding StringFormat="{}{0} Lv.{1}">
                                        <Binding Path="Rank" />
                                        <Binding Path="Level" />
                                    </MultiBinding>
                                </Label.Text>
                            </Label>
                        </VerticalStackLayout>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- Faction Filters -->
        <HorizontalStackLayout Grid.Row="2" Padding="16,8" Spacing="12" HorizontalOptions="Center">
            <!-- All -->
            <Border BackgroundColor="{Binding IsAllSelected, Converter={StaticResource BoolToHighlightConverter}}"
                    Stroke="Transparent" StrokeShape="RoundRectangle 10" Padding="8" HeightRequest="48" WidthRequest="48">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding FilterByFactionCommand}" CommandParameter="" />
                </Border.GestureRecognizers>
                <Label Text="All" FontSize="13" FontAttributes="Bold"
                       TextColor="#e8d8a0" HorizontalOptions="Center" VerticalOptions="Center"
                       FontFamily="OpenSansSemibold" />
            </Border>
            <!-- Order -->
            <Border BackgroundColor="{Binding IsOrderSelected, Converter={StaticResource BoolToHighlightConverter}}"
                    Stroke="Transparent" StrokeShape="RoundRectangle 10" Padding="4" HeightRequest="48" WidthRequest="48">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding FilterByFactionCommand}" CommandParameter="Order" />
                </Border.GestureRecognizers>
                <Image Source="icon_order.png" WidthRequest="36" HeightRequest="36"
                       HorizontalOptions="Center" VerticalOptions="Center" />
            </Border>
            <!-- Chaos -->
            <Border BackgroundColor="{Binding IsChaosSelected, Converter={StaticResource BoolToHighlightConverter}}"
                    Stroke="Transparent" StrokeShape="RoundRectangle 10" Padding="4" HeightRequest="48" WidthRequest="48">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding FilterByFactionCommand}" CommandParameter="Chaos" />
                </Border.GestureRecognizers>
                <Image Source="icon_chaos.png" WidthRequest="36" HeightRequest="36"
                       HorizontalOptions="Center" VerticalOptions="Center" />
            </Border>
            <!-- Arcane -->
            <Border BackgroundColor="{Binding IsArcaneSelected, Converter={StaticResource BoolToHighlightConverter}}"
                    Stroke="Transparent" StrokeShape="RoundRectangle 10" Padding="4" HeightRequest="48" WidthRequest="48">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding FilterByFactionCommand}" CommandParameter="Arcane" />
                </Border.GestureRecognizers>
                <Image Source="icon_arcane.png" WidthRequest="36" HeightRequest="36"
                       HorizontalOptions="Center" VerticalOptions="Center" />
            </Border>
            <!-- Fury -->
            <Border BackgroundColor="{Binding IsFurySelected, Converter={StaticResource BoolToHighlightConverter}}"
                    Stroke="Transparent" StrokeShape="RoundRectangle 10" Padding="4" HeightRequest="48" WidthRequest="48">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding FilterByFactionCommand}" CommandParameter="Fury" />
                </Border.GestureRecognizers>
                <Image Source="icon_fury.png" WidthRequest="36" HeightRequest="36"
                       HorizontalOptions="Center" VerticalOptions="Center" />
            </Border>
        </HorizontalStackLayout>

        <!-- Bottom Nav -->
        <Grid Grid.Row="3"
              Padding="16,0,16,24"
              ColumnDefinitions="*,*,*"
              ColumnSpacing="16">

            <!-- Shop -->
            <Grid Grid.Column="0" WidthRequest="135" HeightRequest="182"
                  HorizontalOptions="Center" VerticalOptions="End">
                <Grid.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding NavigateToCommand}" CommandParameter="ShopPage" />
                </Grid.GestureRecognizers>
                <Path Data="M 3,16 Q 16,16 16,3 L 119,3 Q 119,16 132,16 L 132,119 Q 119,119 119,132 L 16,132 Q 16,119 3,119 Z"
                      Fill="#2a4a2a" Stroke="#8B6914" StrokeThickness="5"
                      WidthRequest="135" HeightRequest="135"
                      HorizontalOptions="Center" VerticalOptions="End"
                      Aspect="None" />
                <Label Text="Shop" FontSize="20" FontAttributes="Bold"
                       TextColor="#e8b830" HorizontalOptions="Center"
                       VerticalOptions="End" Margin="0,0,0,13"
                       FontFamily="OpenSansSemibold" />
                <Image Source="icon_shop.png"
                       WidthRequest="125" HeightRequest="125"
                       HorizontalOptions="Center"
                       VerticalOptions="Start"
                       Margin="0,0,0,0" />
            </Grid>

            <!-- Campaign -->
            <Grid Grid.Column="1" WidthRequest="135" HeightRequest="182"
                  HorizontalOptions="Center" VerticalOptions="End">
                <Grid.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding NavigateToCommand}" CommandParameter="HomePage" />
                </Grid.GestureRecognizers>
                <Path Data="M 3,16 Q 16,16 16,3 L 119,3 Q 119,16 132,16 L 132,119 Q 119,119 119,132 L 16,132 Q 16,119 3,119 Z"
                      Fill="#2a4a2a" Stroke="#8B6914" StrokeThickness="5"
                      WidthRequest="135" HeightRequest="135"
                      HorizontalOptions="Center" VerticalOptions="End"
                      Aspect="None" />
                <Label Text="Campaign" FontSize="20" FontAttributes="Bold"
                       TextColor="#e8b830" HorizontalOptions="Center"
                       VerticalOptions="End" Margin="0,0,0,13"
                       FontFamily="OpenSansSemibold" />
                <Image Source="icon_campaign.png"
                       WidthRequest="125" HeightRequest="125"
                       HorizontalOptions="Center"
                       VerticalOptions="Start"
                       Margin="0,0,0,0" />
            </Grid>

            <!-- Heroes (selected) -->
            <Grid Grid.Column="2" WidthRequest="135" HeightRequest="182"
                  HorizontalOptions="Center" VerticalOptions="End">
                <Path Data="M 3,16 Q 16,16 16,3 L 119,3 Q 119,16 132,16 L 132,119 Q 119,119 119,132 L 16,132 Q 16,119 3,119 Z"
                      Fill="#3a5a3a" Stroke="#e8b830" StrokeThickness="5"
                      WidthRequest="135" HeightRequest="135"
                      HorizontalOptions="Center" VerticalOptions="End"
                      Aspect="None" />
                <Label Text="Heroes" FontSize="20" FontAttributes="Bold"
                       TextColor="#ffe066" HorizontalOptions="Center"
                       VerticalOptions="End" Margin="0,0,0,13"
                       FontFamily="OpenSansSemibold" />
                <Image Source="icon_heroes.png"
                       WidthRequest="125" HeightRequest="125"
                       HorizontalOptions="Center"
                       VerticalOptions="Start"
                       Margin="0,0,0,0" />
            </Grid>
        </Grid>

    </Grid>
</ContentPage>

