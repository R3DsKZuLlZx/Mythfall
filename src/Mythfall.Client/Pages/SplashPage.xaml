<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Mythfall.Client.Pages.SplashPage"
             BackgroundColor="#1a1a2e"
             Shell.NavBarIsVisible="False">

    <Grid VerticalOptions="Fill" HorizontalOptions="Fill">
        <VerticalStackLayout
            x:Name="SplashContent"
            VerticalOptions="Center"
            HorizontalOptions="Center"
            Spacing="20"
            Opacity="0">

            <!-- Game Icon / Symbol -->
            <Border
                StrokeShape="RoundRectangle 30"
                Stroke="#7b2ff7"
                StrokeThickness="3"
                BackgroundColor="#16213e"
                HeightRequest="120"
                WidthRequest="120"
                HorizontalOptions="Center">
                <Label
                    Text="⚔"
                    FontSize="60"
                    HorizontalOptions="Center"
                    VerticalOptions="Center"
                    TextColor="#e94560" />
            </Border>

            <!-- Title -->
            <Label
                x:Name="TitleLabel"
                Text="MYTHFALL"
                FontSize="42"
                FontAttributes="Bold"
                TextColor="#e94560"
                HorizontalOptions="Center"
                FontFamily="OpenSansSemibold"
                CharacterSpacing="6" />

            <!-- Subtitle -->
            <Label
                Text="Collect • Level • Ascend"
                FontSize="16"
                TextColor="#8a8a9a"
                HorizontalOptions="Center"
                FontFamily="OpenSansRegular"
                CharacterSpacing="2" />

        </VerticalStackLayout>

        <!-- Loading indicator at bottom -->
        <VerticalStackLayout
            x:Name="LoadingSection"
            VerticalOptions="End"
            HorizontalOptions="Center"
            Padding="0,0,0,80"
            Spacing="12"
            Opacity="0">

            <ActivityIndicator
                IsRunning="True"
                Color="#7b2ff7"
                HeightRequest="30"
                WidthRequest="30"
                HorizontalOptions="Center" />

            <Label
                Text="Loading..."
                FontSize="13"
                TextColor="#555570"
                HorizontalOptions="Center"
                FontFamily="OpenSansRegular" />

        </VerticalStackLayout>
    </Grid>

</ContentPage>

