<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Mythfall.Client.Pages.SplashPage"
             BackgroundColor="#1a1a2e"
             Shell.NavBarIsVisible="False">

    <Grid VerticalOptions="Fill" HorizontalOptions="Fill">
        <!-- Full background splash image -->
        <Image
            Source="splash.png"
            Aspect="AspectFill"
            VerticalOptions="Fill"
            HorizontalOptions="Fill"
            Opacity="1"
            ZIndex="0" />

        <VerticalStackLayout
            x:Name="SplashContent"
            VerticalOptions="Center"
            HorizontalOptions="Center"
            Spacing="20"
            Opacity="0">
        </VerticalStackLayout>

        <!-- Loading indicator at bottom -->
        <VerticalStackLayout
            x:Name="LoadingSection"
            VerticalOptions="End"
            HorizontalOptions="Center"
            Padding="0,0,0,80"
            Spacing="12"
            Opacity="0">

            <ActivityIndicator
                IsRunning="True"
                Color="#7b2ff7"
                HeightRequest="30"
                WidthRequest="30"
                HorizontalOptions="Center" />

            <Label
                Text="Loading..."
                FontSize="13"
                TextColor="#555570"
                HorizontalOptions="Center"
                FontFamily="OpenSansRegular" />

        </VerticalStackLayout>
    </Grid>

</ContentPage>
