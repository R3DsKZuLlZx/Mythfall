<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Mythfall.Client.Pages.HomePage"
             BackgroundColor="#1a2a1a"
             Title="Mythfall"
             Shell.NavBarIsVisible="False">

    <Grid VerticalOptions="FillAndExpand" HorizontalOptions="FillAndExpand">
        <!-- Full background image -->
        <Image Source="home_background.png"
               Aspect="AspectFill"
               HorizontalOptions="FillAndExpand"
               VerticalOptions="FillAndExpand" />

        <!-- Overlay main content -->
        <Grid RowDefinitions="Auto,*,Auto" VerticalOptions="FillAndExpand">

            <!-- TOP: Resource Bar -->
            <Grid Grid.Row="0"
                  Padding="16,12"
                  ColumnDefinitions="*,*,*">

                <!-- Gold -->
                <HorizontalStackLayout Grid.Column="0" Spacing="8" HorizontalOptions="Center" VerticalOptions="Center">
                    <Image Source="icon_gold_coin.png" WidthRequest="48" HeightRequest="48" VerticalOptions="Center" />
                    <Label x:Name="GoldLabel" Text="1245" FontSize="18" FontAttributes="Bold"
                           TextColor="#e8d8a0" FontFamily="OpenSansSemibold" VerticalOptions="Center" />
                </HorizontalStackLayout>

                <!-- Experience -->
                <HorizontalStackLayout Grid.Column="1" Spacing="8" HorizontalOptions="Center" VerticalOptions="Center">
                    <Image Source="icon_blue_rock.png" WidthRequest="48" HeightRequest="48" VerticalOptions="Center" />
                    <Label x:Name="ExpLabel" Text="530" FontSize="18" FontAttributes="Bold"
                           TextColor="#88ccee" FontFamily="OpenSansSemibold" VerticalOptions="Center" />
                </HorizontalStackLayout>

                <!-- Special Experience -->
                <HorizontalStackLayout Grid.Column="2" Spacing="8" HorizontalOptions="Center" VerticalOptions="Center">
                    <Image Source="icon_pink_rock.png" WidthRequest="48" HeightRequest="48" VerticalOptions="Center" />
                    <Label x:Name="SpecialExpLabel" Text="12" FontSize="18" FontAttributes="Bold"
                           TextColor="#ee88cc" FontFamily="OpenSansSemibold" VerticalOptions="Center" />
                </HorizontalStackLayout>
            </Grid>

            <!-- CENTER: Scenic background area (transparent, so background shows through) -->
            <Grid Grid.Row="1" BackgroundColor="Transparent">
                <!-- No BoxView, let background show -->
            </Grid>

            <!-- BOTTOM: Navigation Buttons -->
            <Grid Grid.Row="2"
                  BackgroundColor="#111a11"
                  Padding="16,12,16,24"
                  ColumnDefinitions="*,*,*"
                  ColumnSpacing="12">

                <!-- Gold border line at top -->
                <BoxView Grid.ColumnSpan="3"
                         HeightRequest="2"
                         Color="#7a6a3a"
                         VerticalOptions="Start" />

                <!-- Campaign -->
                <Border Grid.Column="0"
                        BackgroundColor="#1e2a1e"
                        Stroke="#7a6a3a"
                        StrokeThickness="2"
                        StrokeShape="RoundRectangle 8"
                        Padding="0,12"
                        Margin="0,8,0,0">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnCampaignClicked" />
                    </Border.GestureRecognizers>
                    <VerticalStackLayout HorizontalOptions="Center" Spacing="6">
                        <Label Text="⚔️" FontSize="36" HorizontalOptions="Center" />
                        <Label Text="Campaign" FontSize="14" FontAttributes="Bold"
                               TextColor="#e8b830" HorizontalOptions="Center"
                               FontFamily="OpenSansSemibold" />
                    </VerticalStackLayout>
                </Border>

                <!-- Heroes -->
                <Border Grid.Column="1"
                        BackgroundColor="#1e2a1e"
                        Stroke="#7a6a3a"
                        StrokeThickness="2"
                        StrokeShape="RoundRectangle 8"
                        Padding="0,12"
                        Margin="0,8,0,0">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnHeroesClicked" />
                    </Border.GestureRecognizers>
                    <VerticalStackLayout HorizontalOptions="Center" Spacing="6">
                        <Label Text="🛡️" FontSize="36" HorizontalOptions="Center" />
                        <Label Text="Heroes" FontSize="14" FontAttributes="Bold"
                               TextColor="#e8b830" HorizontalOptions="Center"
                               FontFamily="OpenSansSemibold" />
                    </VerticalStackLayout>
                </Border>

                <!-- Shop -->
                <Border Grid.Column="2"
                        BackgroundColor="#1e2a1e"
                        Stroke="#7a6a3a"
                        StrokeThickness="2"
                        StrokeShape="RoundRectangle 8"
                        Padding="0,12"
                        Margin="0,8,0,0">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnShopClicked" />
                    </Border.GestureRecognizers>
                    <VerticalStackLayout HorizontalOptions="Center" Spacing="6">
                        <Label Text="🏪" FontSize="36" HorizontalOptions="Center" />
                        <Label Text="Shop" FontSize="14" FontAttributes="Bold"
                               TextColor="#e8b830" HorizontalOptions="Center"
                               FontFamily="OpenSansSemibold" />
                    </VerticalStackLayout>
                </Border>

            </Grid>
        </Grid>
    </Grid>

</ContentPage>

