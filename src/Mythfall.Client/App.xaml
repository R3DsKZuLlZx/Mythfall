<?xml version = "1.0" encoding = "UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:Mythfall.Client"
             xmlns:converters="clr-namespace:Mythfall.Client.Converters"
             x:Class="Mythfall.Client.App">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles/Colors.xaml" />
                <ResourceDictionary Source="Resources/Styles/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <converters:BoolToHighlightConverter x:Key="BoolToHighlightConverter" />
            <converters:InvertedBoolConverter x:Key="InvertedBoolConverter" />
            <converters:BoolToSpinButtonConverter x:Key="BoolToSpinButtonConverter" />
            <converters:HpBarWidthConverter x:Key="HpBarWidthConverter" />
            <converters:DefeatedToOpacityConverter x:Key="DefeatedToOpacityConverter" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
